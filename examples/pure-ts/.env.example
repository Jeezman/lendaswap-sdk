# Lendaswap CLI Configuration
# Copy this file to .env and customize as needed

# API base URL (default: https://apilendaswap.lendasat.com/)
# LENDASWAP_API_URL=https://apilendaswap.lendasat.com/

# BIP39 mnemonic phrase (generates new if not set)
# MNEMONIC=abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about

# API key for authentication (optional)
# LENDASWAP_API_KEY=your-api-key-here

# SQLite database path (default: ~/.lendaswap/data.db)
# LENDASWAP_DB_PATH=./data.db
